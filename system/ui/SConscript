import json
import os
import subprocess

Import('env', 'arch', 'common')

renv = env.Clone()

UBUNTU_FOCAL = int(subprocess.check_output('[ -f /etc/os-release ] && . /etc/os-release && [ "$ID" = "ubuntu" ] && [ "$VERSION_ID" = "20.04" ] && echo 1 || echo 0', shell=True, encoding='utf-8').rstrip())

import json
from SCons.Script import File, Command

# Step 1: Read languages from languages.json
import json
import os
from SCons.Script import File, Command, Builder, Glob

import json
import os
from SCons.Script import File, Command, Builder, Glob

import json
import os
from SCons.Script import File, Command, Builder, Glob, Dir

# Step 1: Load languages from languages.json
languages_file = File("raylib/languages.json").abspath
with open(languages_file) as f:
    languages = json.loads(f.read())

# Step 2: Define the absolute path for the translation directory
translation_dir = Dir("raylib/translations").abspath  # Use Dir() for directories
pot_file = os.path.join(translation_dir, "myapp.pot")  # POT file

# Step 3: Define absolute paths for .po and .mo files (gettext translation files)
translation_sources = [os.path.join(translation_dir, f"{lang}.po") for lang in languages.values()]
translation_targets = [po.replace(".po", ".mo") for po in translation_sources]

# Step 4: Get the absolute paths of source files from which translatable strings will be extracted
source_files = [file.abspath for file in Glob('raylib/*.cc')]
print(f"Source files: {source_files}")

# Step 5: Command to extract strings and generate the .pot file
# Add --keyword=_ to recognize _() as translatable strings
xgettext_cmd = f"xgettext --keyword=_ -o {pot_file} " + " ".join(source_files)
xgettext_action = Command(pot_file, source_files, xgettext_cmd)

# Step 6: Create `.po` files if they don't exist using `msginit`
def create_po_if_not_exists(target, source, env):
    po_file = str(target[0])
    pot_file = str(source[0])
    lang_code = os.path.basename(po_file).split(".")[0].split("_")[-1]  # Extract language code
    if not os.path.exists(po_file):
        print(f"Creating {po_file} for {lang_code}")
        os.system(f"msginit --no-translator --locale={lang_code} --input={pot_file} --output={po_file}")

po_builder = Builder(action=create_po_if_not_exists)
env.Append(BUILDERS={'CreatePO': po_builder})

# Step 7: Create .po files (if they don't exist)
po_create_cmds = []
for po_file in translation_sources:
    po_create_cmds.append(env.CreatePO(po_file, pot_file))

# Step 8: Update .po files with new strings from the .pot file (msgmerge)
po_update_cmds = []
for po_file in translation_sources:
    if os.path.exists(po_file):
        print(f"Updating {po_file} with {pot_file}")
        po_update_cmds.append(Command(po_file, pot_file, f"msgmerge --update --backup=off {po_file} {pot_file}"))

# Step 9: Compile .po files into .mo files (msgfmt)
msgfmt_cmds = []
for po_file, mo_file in zip(translation_sources, translation_targets):
    msgfmt_cmds.append(Command(mo_file, po_file, f"msgfmt -o {mo_file} {po_file}"))

# Step 10: Add the commands to the environment for execution
env.Alias('translations', [xgettext_action] + po_create_cmds + po_update_cmds + msgfmt_cmds)





if not UBUNTU_FOCAL:
  rayutil = env.Library("rayutil", ['raylib/util.cc'], LIBS='raylib')
  linked_libs = ['raylib', rayutil, common]
  renv['LIBPATH'] += [f'#third_party/raylib/{arch}/']

  mac_frameworks = []
  if arch == "Darwin":
    mac_frameworks += ['OpenCL', 'CoreVideo', 'Cocoa', 'GLUT', 'CoreFoundation', 'OpenGL', 'IOKit']
  elif arch == 'larch64':
    linked_libs += ['GLESv2', 'GL', 'EGL', 'wayland-client', 'wayland-egl']
  else:
    linked_libs += ['OpenCL', 'dl', 'pthread']

  if arch != 'aarch64':
    renv.Program("spinner", ["raylib/spinner.cc"], LIBS=linked_libs, FRAMEWORKS=mac_frameworks)
